# ============================================================
# Archivo de variables de entorno para generateArticle.py
# Copia este fichero como .env y rellena los valores reales:
#   cp .env.example .env
#
# Nota: generateArticle.py NO requiere MongoDB.
# El artículo generado se exporta a un fichero JSON local.
# Usa los argumentos CLI para indicar el tema:
#   python generateArticle.py --tag "JWT Authentication" --category "Spring Boot" --subcategory "Spring Security"
# ============================================================

# -------- OpenAI / ChatGPT --------
OPENAIAPIKEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Para usar ChatGPT, elige un modelo OpenAI:
OPENAI_MODEL=gpt-4o
# Ejemplos de modelos ChatGPT: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# -------- Google Gemini --------
# Para usar Gemini, establece GEMINI_API_KEY y cambia OPENAI_MODEL a un modelo Gemini:
GEMINI_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Ejemplos de modelos Gemini: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash

# -------- Ollama (LLM local) --------
# Para usar Ollama, establece OLLAMA_BASE_URL y cambia OPENAI_MODEL al modelo local:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3
# Ejemplos de modelos Ollama: llama3, mistral, codellama, gemma, phi3
# No requiere clave de API (OPENAIAPIKEY no es necesaria)

# -------- Temperatura de generación --------
# Valores entre 0.0 (más determinista) y 1.0 (más creativo). Por defecto: 0.7 (artículo), 0.9 (título)
AI_TEMPERATURE_ARTICLE=0.7
AI_TEMPERATURE_TITLE=0.9

# -------- Sitio web (URL base sin barra final) --------
SITE=https://tusitio.com

# -------- Autor --------
AUTHOR_USERNAME=adminUser

# -------- Notificaciones por email (SMTP) --------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
FROM_EMAIL=tu_correo@gmail.com
NOTIFY_EMAIL=tu_correo@gmail.com

# -------- Opciones de comportamiento --------
# Enviar emails detallados (true/false)
NOTIFY_VERBOSE=true
# Limitar a 1 artículo por semana (true/false) — reservado para uso futuro
LIMIT_PUBLICATION=true
# Enviar por email el prompt antes de llamar a OpenAI (true/false)
SEND_PROMPT_EMAIL=false
# Idioma de los artículos generados (código ISO 639-1)
# Ejemplos: es (español), en (inglés), fr (francés), de (alemán), it (italiano), pt (portugués)
ARTICLE_LANGUAGE=es
